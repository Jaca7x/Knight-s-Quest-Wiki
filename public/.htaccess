<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Garante que o index.html não entre em loop
  RewriteRule ^index\.html$ - [L]

  # Se o que o usuário pediu NÃO for um arquivo real (como imagem/js)
  # E NÃO for uma pasta real...
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # ...então mande ele carregar o index.html, independente da URL
  RewriteRule . /index.html [L]
</IfModule>

<FilesMatch "\.(html|sw\.js|manifest\.webmanifest)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>

# 2. SE A HOSTINGER USAR LITESPEED (COMUM)
# Força o cache do servidor a limpar esses arquivos também
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
</IfModule>